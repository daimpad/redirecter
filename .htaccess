Options -Indexes

RewriteEngine On

# Statische Dateien und PHP-Skripte direkt durchlassen
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# index.php direkt erreichbar lassen
RewriteRule ^index\.php$ - [L]

# Alle anderen Anfragen als Slug an redirect.php weiterleiten
RewriteRule ^([A-Za-z0-9_-]+)/?$ redirect.php?s=$1 [L,QSA]
