Options -Indexes

RewriteEngine On

# HTTP → HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Statische Dateien und Verzeichnisse direkt durchlassen
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Alle anderen Anfragen als Slug an redirect.php weiterleiten
RewriteRule ^([A-Za-z0-9_-]+)/?$ redirect.php?s=$1 [L,QSA]

# Interne Hilfsdateien vor direktem HTTP-Zugriff schützen
<FilesMatch "^(config|functions)\.php$">
    Require all denied
</FilesMatch>
